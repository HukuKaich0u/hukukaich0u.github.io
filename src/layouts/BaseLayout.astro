---
import "../styles/global.css";
import { copyByLang, type Lang } from "../data/i18n";
import SiteFooter from "../components/SiteFooter.astro";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
  pagePath?: string;
  title?: string;
  description?: string;
}

const {
  lang,
  pagePath = "/",
  title = "Koki Aoyagi",
  description = "Personal site"
} = Astro.props;

const copy = copyByLang[lang];
const normalizedPath = pagePath.startsWith("/") ? pagePath : `/${pagePath}`;
const toLocalePath = (targetLang: Lang) =>
  normalizedPath === "/" ? `/${targetLang}` : `/${targetLang}${normalizedPath}`;
const repositoryUrl = "https://github.com/hukukaich0u/hukukaich0u.github.io";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        const key = "theme-preference";
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const readMode = () => {
          const stored = localStorage.getItem(key);
          return stored === "light" || stored === "dark" ? stored : "system";
        };
        const resolveTheme = (mode) =>
          mode === "dark" || (mode === "system" && media.matches) ? "dark" : "light";
        const mode = readMode();
        document.documentElement.dataset.theme = resolveTheme(mode);
        document.documentElement.dataset.themeMode = mode;
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top">
    <header class="site-header">
      <nav class="container nav">
        <a href={repositoryUrl} class="brand external-link" target="_blank" rel="noreferrer"
          >hukukaich0u.github.io</a
        >
        <div class="lang-switch" aria-label={copy.languageLabel}>
          <span>(</span>
          <a href={toLocalePath("ja")} class={lang === "ja" ? "active" : undefined}>日本語</a>
          <span>/</span>
          <a href={toLocalePath("en")} class={lang === "en" ? "active" : undefined}>English</a>
          <span>)</span>
        </div>
        <div class="theme-switch">
          <button
            id="theme-toggle"
            type="button"
            class="theme-toggle"
            aria-label={copy.themeToggleLabel}
          >
            <span class="theme-icon theme-sun" aria-hidden="true">
              <Icon name="lucide:sun" />
            </span>
            <span class="theme-icon theme-moon" aria-hidden="true">
              <Icon name="lucide:moon" />
            </span>
          </button>
        </div>
      </nav>
    </header>
    <main class="container main-content">
      <slot />
    </main>
    <SiteFooter lang={lang} />
    <script is:inline>
      (() => {
        const key = "theme-preference";
        const button = document.querySelector("#theme-toggle");
        const media = window.matchMedia("(prefers-color-scheme: dark)");

        if (!(button instanceof HTMLButtonElement)) return;

        const readMode = () => {
          const stored = localStorage.getItem(key);
          return stored === "light" || stored === "dark" ? stored : "system";
        };

        const resolveTheme = (mode) => {
          if (mode === "dark") return "dark";
          if (mode === "light") return "light";
          return media.matches ? "dark" : "light";
        };

        const apply = (mode) => {
          const theme = resolveTheme(mode);
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.themeMode = mode;
        };

        apply(readMode());

        button.addEventListener("click", () => {
          const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
          const next = current === "dark" ? "light" : "dark";
          localStorage.setItem(key, next);
          apply(next);
        });

        media.addEventListener("change", () => {
          if (readMode() === "system") {
            apply("system");
          }
        });
      })();
    </script>
  </body>
</html>
